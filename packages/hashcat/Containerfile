FROM ubuntu:24.04

RUN apt update && apt install fish gcc make g++ perl python3 git rustc -y
RUN fish -c "set -U fish_greeting"
WORKDIR /root
RUN git clone https://github.com/hashcat/hashcat
WORKDIR /root/hashcat
RUN make
RUN make install
WORKDIR /root
RUN rm -rf /root/*
RUN apt remove gcc make g++ git rustc -y && apt autoremove -y
CMD ["fish"]
