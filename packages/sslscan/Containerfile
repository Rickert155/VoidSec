FROM ubuntu:24.04

RUN apt update && apt install fish gcc make git zlib1g-dev -y
RUN /usr/bin/fish -c "set -U fish_greeting"
WORKDIR /root
RUN git clone https://github.com/rbsec/sslscan
WORKDIR /root/sslscan
RUN make static
RUN make install
WORKDIR /root
RUN rm -rf *
RUN apt remove gcc make git zlib1g-dev -y && apt autoremove -y
CMD ["fish"]
