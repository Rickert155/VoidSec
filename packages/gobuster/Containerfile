FROM alpine 

RUN apk add --no-cache fish go git
RUN /usr/bin/fish -c "set -U fish_greeting"
WORKDIR /root
RUN git clone https://github.com/OJ/gobuster
WORKDIR /root/gobuster
RUN go mod tidy
RUN go build
RUN apk del git go
RUN cp gobuster /usr/local/bin/gobuster
WORKDIR /root
RUN rm -rf *
CMD ["fish"]
