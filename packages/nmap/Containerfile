FROM ubuntu:24.04

RUN apt update && apt install fish gcc make git g++ -y
RUN /usr/bin/fish -c "set -U fish_greeting"
WORKDIR /root
RUN git clone https://github.com/nmap/nmap
WORKDIR /root/nmap
RUN ./configure --prefix=/usr
RUN make
RUN make install
WORKDIR /root
RUN apt remove gcc make git g++ -y && apt autoremove -y
CMD ["fish"]
