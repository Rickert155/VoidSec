FROM ubuntu:24.04

RUN apt update && apt install fish gcc make git -y
RUN /usr/bin/fish -c "set -U fish_greeting"
WORKDIR /root
RUN git clone https://github.com/vanhauser-thc/thc-hydra hydra
WORKDIR /root/hydra
RUN ./configure --prefix=/usr
RUN make
RUN make install
WORKDIR /root
RUN apt remove gcc make git -y && apt autoremove -y
CMD ["fish"]
